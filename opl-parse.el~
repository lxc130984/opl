;; collect amount
;;------------------------------------------------------------------------------


(cl-defun opl--collect-traits-in-buf (buf)
  "Collect traits in the BUF."
  (with-current-buffer buf
    (unless (derived-mode-p 'org-mode)
      (org-mode))
    (let ((table (make-hash-table :test 'equal)))
      (org-map-entries
       (lambda ()
	 (when-let* ((trait (opl--collect-trait-single))
		     (trait-name (opl-trait-name trait)))
	   (if (gethash trait-name table)
	       (error "repeat trait : %s" trait-name)
	     (puthash trait-name trait table))))
       "+LEVEL=1" nil 'file)
      table)))

(cl-defun opl--collect-traits-in-file (&optional file)
  "Collect impls in the FILE."
  (let* ((abs-file (if file
		       (expand-file-name file)
		     (buffer-file-name)))
	 (buf (if file
		  (find-file-noselect file)
		(current-buffer))))
    (unwind-protect
	(with-current-buffer buf
	  (unless (derived-mode-p 'org-mode) (org-mode))
	  (opl--collect-traits-in-buf buf))
      ;; (when (and file
      ;; 		 (not (eq buf (current-buffer))))
      ;; 	(kill-buffer buf))
      )))


