;;------------------------------------------------------------------------------
;; impl collect
;;------------------------------------------------------------------------------

(cl-defun opl--parse-impl (ref-string type)
  "Reply REF-STRING, return the struct or trait object (or nil).
TYPE is 'struct or 'trait."
  (cond
   ((string-match org-link-any-re ref-string)
    (when-let* ((objects (org-element-parse-secondary-string ref-string '(link) nil))
		(link (car objects))
		(_ (and (eq (org-element-type link) 'link)
			(string= (org-element-property :type link) "file")))
		(path (expand-file-name (org-element-property :path link)))
		(search-option (substring-no-properties (org-element-property :search-option link) (if (eq type 'trait)
												       (length "*trait ")
												     (length "*struct ")))))
	(let ((table (if (eq type 'trait)
			   (opl--collect-traits-in-file path)
			 (opl--collect-structs-in-file path))))
	    (gethash search-option table))))
   (t
    (let ((table (if (eq type 'trait)
		     (opl--collect-traits-in-file)
		   (opl--collect-structs-in-file))))
      (gethash ref-string table)))))


(cl-defun opl--collect-impl-single ()
  "Collect the impl A for B under the single tree,that A is from STRUCT-FILE ,and B is from TRAIT-FILE."
  (let ((heading (substring-no-properties (org-get-heading t t t t))))
    (when (and heading
	       (string-prefix-p "impl " heading))
      (let* ((heading-info (substring heading (length "impl ")))
	     (_ (string-match "\\`\\(.+\\) for \\(.+\\)\\'" heading-info))
	     (trait-part (match-string 1 heading-info))
	     (struct-part (match-string 2 heading-info))
	     (trait  (opl--parse-impl trait-part 'trait))
	     (struct (opl--parse-impl struct-part 'struct)))
	(when (and struct trait)
	(make-opl-impl
	 :file (buffer-file-name)
	 :marker (point-marker)
	 :trait trait
	 :struct struct
	 :introduction (opl--get-heading-content)
	 :detail-tree (opl--collect-subtree :with-content t :skip-tags nil)))))))



(cl-defun opl--collect-impls-in-buf (buf)
  "Collect impls in the BUF."
  (with-current-buffer buf
    (unless (derived-mode-p 'org-mode)
      (org-mode))
    (let ((table (make-hash-table :test 'equal)))
      (org-map-entries
       (lambda ()
	 (when-let* ((impl (opl--collect-impl-single))
		     (impl-trait-and-struct-name (cons (opl-impl-trait impl) (opl-impl-struct impl))))
	   (if (gethash impl-trait-and-struct-name table)
	       (error "repeat impl : %s" impl-trait-and-struct-name)
	     (puthash impl-trait-and-struct-name impl table))))
       "+LEVEL=1" nil 'file)
      table)))


(cl-defun opl--collect-impls-in-file (&optional file)
  "Collect impls in the FILE."
  (let* ((abs-file (if file
		       (expand-file-name file)
		     (buffer-file-name)))
	 (buf (if file
		  (find-file-noselect file)
		(current-buffer))))
    (unwind-protect
	(with-current-buffer buf
	  (unless (derived-mode-p 'org-mode) (org-mode))
	  (opl--collect-impls-in-buf buf))
      (when (and file
		 (not (eq buf (current-buffer))))
	(kill-buffer buf)))))


