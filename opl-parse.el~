(defun opl--get-heading-content ()
  "Returns the direct text under the current title between *.. and **...The point must be at heading."
  (save-excursion
    (forward-line 1)
    (let ((start (point))
	  (end (or (and (re-search-forward org-heading-regexp nil t)
			(line-beginning-position))
		   (point-max))))
      (string-trim (buffer-substring-no-properties start end)))))


(cl-defun opl--collect-subtree (&key with-content skip-tags)
  "Collect the org subtree.if WITH-CONTENT isnot nil: means collect the subtree with content.SKIP-TAGS means not collect the subtree with tag that is in SKIP-TAGS."
  (let ((heading (substring-no-properties (org-get-heading t t t t)))
	(content (when with-content (opl--get-heading-content)))
	(children nil))
    (save-excursion
      (when (org-goto-first-child)
	(unless (and skip-tags
		     (seq-intersection (org-get-tags nil t) skip-tags))
	  (push (opl--collect-subtree :with-content with-content :skip-tags skip-tags) children)))
      (while (org-goto-sibling)
	(unless (and skip-tags
		     (seq-intersection (org-get-tags nil t) skip-tags))
	  (push (opl--collect-subtree :with-content with-content :skip-tags skip-tags) children))))
    (if with-content
	(make-opl-content-node
	 :head heading
	 :content (or content "")
	 :children (nreverse children))
      (make-opl-node
       :head heading
       :children children))))

;;------------------------------------------------------------------------------
;; collect
;;------------------------------------------------------------------------------
(cl-defun opl--collect-trait-single ()
  "Collect the trait under the single tree."
  (let ((heading (substring-no-properties (org-get-heading t t t t))))
    (when (and heading
	       (string-prefix-p "trait " heading))
      (make-opl-trait
       :file (buffer-file-name)
       :marker (point-marker)
       :name (substring heading (length "trait "))
       :trait-tree (opl--collect-subtree :with-content nil :skip-tags '("autolink"))))))

(cl-defun opl--collect-struct-single ()
  "Collect the impl under the single tree."
  (let ((heading (substring-no-properties (org-get-heading t t t t))))
    (when (and heading
	       (string-prefix-p "struct " heading))
      (make-opl-struct
       :file (buffer-file-name)
       :marker (point-marker)
       :name (substring heading (length "struct "))
       :introduction (opl--get-heading-content)
       :struct-tree (opl--collect-subtree :with-content t :skip-tags '("autolink"))))))

